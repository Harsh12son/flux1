{
    "$schema": "https://schema.tauri.app/config/2",
    "identifier": "com.flux.launcher",
    "productName": "Flux Launcher",
    "version": "0.1.0",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:5173",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Flux Launcher",
                "width": 800,
                "height": 520,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "visible": false
            }
        ]
    }
}